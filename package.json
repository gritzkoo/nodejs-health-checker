{
  "name": "nodejs-health-checker",
  "version": "2.0.0",
  "type": "module",
  "description": "Simple Nodejs package to simplify applications based in Node, to trace the healthy of the pods",
  "author": "Gritzko D. Kleiner <gritzkoo@hotmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gritzkoo/nodejs-health-checker.git"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "healthcheck",
    "health-check",
    "health-checker",
    "healthchecker",
    "pods"
  ],
  "bugs": {
    "url": "https://github.com/gritzkoo/nodejs-health-checker/issues"
  },
  "homepage": "https://github.com/gritzkoo/nodejs-health-checker#readme",
  "scripts": {
    "dev": "nodemon --watch \"src/\" --exec \"ts-node src/index.ts\" -e ts",
    "test": "jest --forceExit --testTimeout=60000",
    "test:coverage": "jest --collect-coverage --forceExit --testTimeout=60000",
    "format": "eslint --fix \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/memcached": "^2.2.10",
    "@types/node": "^22.10.5",
    "@types/node-fetch": "^2.6.12",
    "@types/redis": "^4.0.11",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.716.0",
    "mariadb": "^3.5.1",
    "memcached": "^2.2.2",
    "mysql2": "^3.11.5",
    "node-fetch": "^3.3.2",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "redis": "^5.11.0",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7"
  },
  "files": [
    "dist/**/*"
  ]
}
